[gd_scene format=3 uid="uid://gesture_test_2d"]

[ext_resource type="Script" path="res://Scripts/gesture_test_2d.gd"  id="1_test2d"]
[ext_resource type="Script" path="res://Scripts/gesture_recognition.gd" id="2_grec"]
[ext_resource type="Script" path="res://Scripts/draw_canvas.gd"      id="3_canvas"]

; ---------------------------------------------------------------------------
; Label settings
; ---------------------------------------------------------------------------
[sub_resource type="LabelSettings" id="LabelSettings_title"]
font_size = 26
font_color = Color(0.75, 0.85, 1.0, 1)

[sub_resource type="LabelSettings" id="LabelSettings_result"]
font_size = 32
font_color = Color(0.3, 1.0, 0.55, 1)

[sub_resource type="LabelSettings" id="LabelSettings_status"]
font_size = 16
font_color = Color(0.65, 0.65, 0.75, 1)

[sub_resource type="LabelSettings" id="LabelSettings_hint"]
font_size = 18
font_color = Color(0.35, 0.35, 0.45, 0.7)

; ---------------------------------------------------------------------------
; Button styles
; ---------------------------------------------------------------------------
[sub_resource type="StyleBoxFlat" id="Style_BtnClear"]
bg_color = Color(0.35, 0.1, 0.1, 1)
corner_radius_top_left = 6
corner_radius_top_right = 6
corner_radius_bottom_right = 6
corner_radius_bottom_left = 6

[sub_resource type="StyleBoxFlat" id="Style_BtnRecog"]
bg_color = Color(0.08, 0.3, 0.18, 1)
corner_radius_top_left = 6
corner_radius_top_right = 6
corner_radius_bottom_right = 6
corner_radius_bottom_left = 6

; ---------------------------------------------------------------------------
; Canvas border
; ---------------------------------------------------------------------------
[sub_resource type="StyleBoxFlat" id="Style_Canvas"]
bg_color = Color(0.04, 0.04, 0.07, 1)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.3, 0.45, 0.9, 0.5)
corner_radius_top_left = 6
corner_radius_top_right = 6
corner_radius_bottom_right = 6
corner_radius_bottom_left = 6

; ===========================================================================
; Scene tree
; ===========================================================================

[node name="GestureTest2D" type="Node"]
script = ExtResource("1_test2d")

[node name="GestureRecognition" type="Node" parent="."]
script = ExtResource("2_grec")

; -- Background --
[node name="UI" type="CanvasLayer" parent="."]

[node name="BG" type="ColorRect" parent="UI"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.07, 0.07, 0.11, 1)

; -- Main layout --
[node name="VBox" type="VBoxContainer" parent="UI"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_constants/separation = 14
offset_left = 24
offset_top = 24
offset_right = -24
offset_bottom = -24

[node name="TitleLabel" type="Label" parent="UI/VBox"]
layout_mode = 2
text = "Gesture Recognition — Desktop Test"
label_settings = SubResource("LabelSettings_title")
horizontal_alignment = 1

[node name="StatusLabel" type="Label" parent="UI/VBox"]
layout_mode = 2
text = "Click and drag inside the draw area to record a gesture."
label_settings = SubResource("LabelSettings_status")
horizontal_alignment = 1

; -- Draw area: panel border + DrawCanvas on top --
[node name="DrawAreaContainer" type="PanelContainer" parent="UI/VBox"]
layout_mode = 2
size_flags_vertical = 3
custom_minimum_size = Vector2(0, 350)
theme_override_styles/panel = SubResource("Style_Canvas")

[node name="DrawCanvas" type="Control" parent="UI/VBox/DrawAreaContainer"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
mouse_filter = 0
script = ExtResource("3_canvas")

[node name="HintLabel" type="Label" parent="UI/VBox/DrawAreaContainer/DrawCanvas"]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -140
offset_top = -15
offset_right = 140
offset_bottom = 15
text = "Draw your gesture here"
label_settings = SubResource("LabelSettings_hint")
horizontal_alignment = 1
vertical_alignment = 1
mouse_filter = 2

; -- Buttons --
[node name="HBox" type="HBoxContainer" parent="UI/VBox"]
layout_mode = 2
theme_override_constants/separation = 16
alignment = 1

[node name="ClearButton" type="Button" parent="UI/VBox/HBox"]
layout_mode = 2
custom_minimum_size = Vector2(160, 48)
text = "Clear"
theme_override_styles/normal = SubResource("Style_BtnClear")
theme_override_font_sizes/font_size = 18

[node name="RecognizeButton" type="Button" parent="UI/VBox/HBox"]
layout_mode = 2
custom_minimum_size = Vector2(200, 48)
text = "Recognise"
theme_override_styles/normal = SubResource("Style_BtnRecog")
theme_override_font_sizes/font_size = 18

; -- Results --
[node name="ResultLabel" type="Label" parent="UI/VBox"]
layout_mode = 2
text = ""
label_settings = SubResource("LabelSettings_result")
horizontal_alignment = 1

[node name="FooterLabel" type="Label" parent="UI/VBox"]
layout_mode = 2
text = "Templates: res://gestures/p_c_data.json"
label_settings = SubResource("LabelSettings_status")
horizontal_alignment = 1
